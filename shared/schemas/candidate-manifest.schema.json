{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vsf.local/schemas/candidate-manifest.schema.json",
  "title": "Candidate Manifest",
  "version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dataset_id",
    "manifest_id",
    "generated_at",
    "generator_version",
    "random_seed",
    "samples"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_id": {"type": "string", "minLength": 1},
    "manifest_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "generator_version": {"type": "string", "minLength": 1},
    "random_seed": {"type": "integer"},
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "source_video_id",
          "source_video_path",
          "source_video_duration_ms",
          "clip_path",
          "clip_type",
          "candidate_rule",
          "start_ms",
          "end_ms",
          "duration_ms",
          "metadata"
        ],
        "properties": {
          "sample_id": {"type": "string", "minLength": 1},
          "source_video_id": {"type": "string", "minLength": 1},
          "source_video_path": {"type": "string", "minLength": 1},
          "source_video_duration_ms": {"type": "integer", "minimum": 1},
          "clip_path": {"type": "string", "minLength": 1},
          "clip_type": {"type": "string", "enum": ["event", "background"]},
          "candidate_rule": {"type": "string", "minLength": 1},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 1},
          "duration_ms": {"type": "integer", "minimum": 1},
          "metadata": {"type": "object"}
        }
      }
    }
  }
}
